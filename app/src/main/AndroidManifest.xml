<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
        <intent>
            <action android:name="android.speech.action.RECOGNIZE_SPEECH" />
        </intent>
    </queries>

    <application
        android:name=".TerminalApp"
        android:allowBackup="false"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Terminal"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name=".ui.HomeActivity"
            android:exported="true"
            android:launchMode="singleTop" />

        <activity-alias
            android:name=".ui.LauncherGreen"
            android:targetActivity=".ui.HomeActivity"
            android:exported="true"
            android:enabled="true"
            android:icon="@mipmap/ic_launcher_green"
            android:roundIcon="@mipmap/ic_launcher_green"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".ui.LauncherColor"
            android:targetActivity=".ui.HomeActivity"
            android:exported="true"
            android:enabled="false"
            android:icon="@mipmap/ic_launcher_color"
            android:roundIcon="@mipmap/ic_launcher_color"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity
            android:name=".ui.TerminalActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:launchMode="singleTask"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|smallestScreenSize" />

        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:label="SETTINGS" />

        <activity
            android:name=".ui.ServerEditActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <service
            android:name=".service.TerminalService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <service
            android:name=".service.QuickSettingsTile"
            android:exported="true"
            android:icon="@drawable/ic_terminal"
            android:label="@string/tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
    </application>
</manifest>
