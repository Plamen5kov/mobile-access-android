<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Icon section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ICON"
            android:textColor="?android:textColorSecondary"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:id="@+id/pick_green"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:selectableItemBackground">

                <ImageView
                    android:id="@+id/preview_green"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/label_green"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GREEN"
                    android:textColor="#33ff33"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:letterSpacing="0.1" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/pick_color"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:selectableItemBackground">

                <ImageView
                    android:id="@+id/preview_color"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/label_color"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COLOR"
                    android:textColor="?android:textColorPrimary"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:letterSpacing="0.1" />
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:listDivider"
            android:layout_marginBottom="16dp" />

        <!-- Theme section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THEME"
            android:textColor="?android:textColorSecondary"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/pick_dark"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DARK"
                android:gravity="center"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:textColor="?android:textColorPrimary"
                android:letterSpacing="0.1"
                android:padding="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:selectableItemBackground" />

            <TextView
                android:id="@+id/pick_light"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LIGHT"
                android:gravity="center"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:textColor="?android:textColorPrimary"
                android:letterSpacing="0.1"
                android:padding="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:selectableItemBackground" />

            <TextView
                android:id="@+id/pick_system"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SYSTEM"
                android:gravity="center"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:textColor="?android:textColorPrimary"
                android:letterSpacing="0.1"
                android:padding="14dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:selectableItemBackground" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
