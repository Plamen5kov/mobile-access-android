<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#0a0a0a">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#111111">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="&gt;_ TERMINAL"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#33ff33"
            android:fontFamily="monospace"
            android:letterSpacing="0.1" />

        <ImageButton
            android:id="@+id/btn_ssh_key"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_key"
            android:contentDescription="SSH Key"
            android:background="?android:selectableItemBackgroundBorderless"
            android:padding="10dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2a2a2a" />

    <TextView
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NO SERVERS CONFIGURED.\nADD ONE BELOW."
        android:textSize="13sp"
        android:textColor="#0d5a0d"
        android:gravity="center"
        android:fontFamily="monospace"
        android:padding="48dp"
        android:letterSpacing="0.05"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/server_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="12dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2a2a2a" />

    <Button
        android:id="@+id/btn_add_server"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="[ + ADD SERVER ]"
        android:textColor="#33ff33"
        android:fontFamily="monospace"
        android:letterSpacing="0.05"
        android:background="@drawable/card_background"
        android:padding="14dp" />

</LinearLayout>
